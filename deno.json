{
  "workspace": ["./packages/data-table-sqlite-turso", "./packages/ssg"],
  "fmt": {
    "singleQuote": true,
    "semiColons": false,
    "lineWidth": 100,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "exclude": ["prefer-const", "require-await"]
    }
  },
  "tasks": {
    "test": "deno test --allow-read --allow-write --allow-env",
    "check": "deno check packages/*/src"
  }
}
